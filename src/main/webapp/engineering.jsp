            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow">
            <img src="images/it.webp" class="card-img-top" alt="IT" />
            <div class="card-body">
              <h5 class="card-title">Information Technology</h5>
              <p class="card-text">
                Focuses on networks, systems, IT services, and cybersecurity.
              </p>
              <button class="btn btn-primary engineering-detail-btn" type="button" data-field="it">View Details</button>
            </div>
          </div>
        </div>
      </div>

      <div class="engineering-info-panel mt-4" id="engineeringInfoPanel" aria-live="polite">
        <span>Selected Engineering Field</span>
        <h3>Choose a field above</h3>
        <p>Click any View Details button to explore overview, roadmap, career options, and skills inside this panel.</p>
