              <h5 class="card-title">Mechanical Engineering</h5>
              <p class="card-text">
                Deals with machines, mechanics, design, and thermal sciences.
              </p>
              <button class="btn btn-primary engineering-detail-btn" type="button" data-field="mechanical">View Details</button>
            </div>
          </div>
        </div>
